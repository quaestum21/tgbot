# Telegram API credentials (from https://my.telegram.org)
API_ID=12345678
API_HASH=your_api_hash_here
PHONE=+1234567890
LOGIN=MySession

# Session string for Docker deployment (optional, overrides file-based auth)
# Generate with: python export_session.py
SESSION_STRING=

# Monitoring configuration
GROUP_IDS=@group1,-1001234567890
KEYWORDS=keyword1,keyword2,keyword3
TARGET_USER=@your_username
